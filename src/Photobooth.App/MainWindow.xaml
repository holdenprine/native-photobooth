<Window x:Class="Photobooth.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Photobooth"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Topmost="True"
        Background="{StaticResource KioskBackground}"
        KeyDown="Window_KeyDown">

    <Grid Margin="48">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Brand -->
        <TextBlock Grid.Row="0"
                   Text="PHOTOBOOTH"
                   FontFamily="Segoe UI Semibold"
                   FontSize="42"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource BrandForeground}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,24" />

        <!-- Camera preview — swipe horizontally to cycle filters -->
        <Border x:Name="PreviewArea"
                Grid.Row="1"
                Background="{StaticResource PreviewBackground}"
                BorderBrush="{StaticResource PreviewBorder}"
                BorderThickness="2"
                CornerRadius="4"
                ClipToBounds="True"
                Cursor="Hand"
                MouseLeftButtonDown="PreviewArea_MouseLeftButtonDown"
                MouseLeftButtonUp="PreviewArea_MouseLeftButtonUp"
                LostMouseCapture="PreviewArea_LostMouseCapture">
            <Grid>
                <TextBlock x:Name="PreviewPlaceholder"
                           Text="Camera preview"
                           FontFamily="Segoe UI"
                           FontSize="28"
                           Foreground="{StaticResource MutedForeground}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />

                <!-- Live feed / captured frame will replace this Image later -->
                <Image x:Name="PreviewImage"
                       Stretch="UniformToFill"
                       Visibility="Collapsed" />

                <!-- Current filter name — shows briefly on start / swipe -->
                <Border x:Name="FilterNameOverlay"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Stretch"
                        Background="#990E0D0C"
                        Padding="24,16"
                        Visibility="Collapsed">
                    <TextBlock x:Name="FilterNameText"
                               FontFamily="Segoe UI Semibold"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrandForeground}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center" />
                </Border>
            </Grid>
        </Border>

        <!-- Guest prompt -->
        <TextBlock Grid.Row="2"
                   x:Name="StatusText"
                   Text="Swipe the preview to change filters, then tap to capture"
                   FontFamily="Segoe UI"
                   FontSize="26"
                   Foreground="{StaticResource BrandForeground}"
                   HorizontalAlignment="Center"
                   Margin="0,32,0,28"
                   TextAlignment="Center" />

        <!-- Capture button — large enough for touch -->
        <Button Grid.Row="3"
                x:Name="CaptureButton"
                Content="TAKE PHOTO"
                Height="88"
                MinWidth="320"
                MaxWidth="480"
                HorizontalAlignment="Center"
                FontFamily="Segoe UI Semibold"
                FontSize="28"
                FontWeight="SemiBold"
                Cursor="Hand"
                Click="CaptureButton_Click"
                Style="{StaticResource CaptureButtonStyle}" />

        <!-- Close — touch exit; Esc still works via Window_KeyDown -->
        <Button Grid.Row="4"
                x:Name="CloseButton"
                Content="CLOSE"
                Height="64"
                MinWidth="200"
                MaxWidth="320"
                HorizontalAlignment="Center"
                FontFamily="Segoe UI Semibold"
                FontSize="22"
                FontWeight="SemiBold"
                Cursor="Hand"
                Click="CloseButton_Click"
                Style="{StaticResource CloseButtonStyle}"
                Margin="0,16,0,0" />
    </Grid>
</Window>
